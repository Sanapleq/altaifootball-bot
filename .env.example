# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=8481213735:AAEJVIBzk25PqVp9CeotXhLFUq8NAx0Tn9I

# Базовый URL сайта
BASE_URL=https://www.altaifootball.ru

# Таймаут HTTP-запросов в секундах
REQUEST_TIMEOUT=30

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к SQLite базе данных
DB_PATH=data/bot.db

# === DEBUG ===
# Сохранять HTML проблемных страниц в debug_html/
DEBUG_SAVE_HTML=false

# Использовать curl_cffi как промежуточный fallback (403/500/503/пустой HTML)
# По умолчанию True — обходит простые защиты сайта
USE_CURL_CFFI=true

# Использовать Playwright как fallback при ошибках httpx (403/500/503)
# Требует: pip install playwright && playwright install chromium
USE_PLAYWRIGHT_FALLBACK=false
